# Per-agent LLM model selection — defaults to claude-sonnet-4-6
PARSER_AGENT_MODEL=claude-sonnet-4-6
PMO_AGENT_MODEL=claude-sonnet-4-6
CONTRACT_GATE_MODEL=claude-sonnet-4-6
PM_AGENT_MODEL=claude-sonnet-4-6

# Global OpenAI fallback model (used as a fallback across all agents)
FALLBACK_MODEL=gpt-4o

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=agile-agent-program

# SQLite checkpointer path
CHECKPOINT_DB_PATH=./checkpoints.db

# Maximum retries before forcing escalation
MAX_RETRIES=3

# Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API key (used as fallback model across all agents)
OPENAI_API_KEY=your-openai-api-key

# Auto-approve escalation interrupts in dev (set to false in production)
AUTO_APPROVE_ESCALATION=true

# Dark factory modes for testing (happy | failed | partial)
FACTORY_A_MODE=happy
FACTORY_B_MODE=happy
